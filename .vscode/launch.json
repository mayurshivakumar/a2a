{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "A2A: All Agents",
      "program": "${workspaceFolder}/src/index.js",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "A2A: Vitest Watch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "A2A: Current Test",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": true
    }
  ],
  "compounds": [
    {
      "name": "A2A: Full Development",
      "configurations": ["A2A: All Agents", "A2A: Vitest Watch"],
      "stopAll": true
    },
    {
      "name": "A2A: Servers + Current Test",
      "configurations": ["A2A: All Agents", "A2A: Current Test"],
      "stopAll": true
    }
  ]
}
